# RohitOS Environment Variables Configuration
# Copy this file to .env and replace the placeholders with your actual keys.

# ==========================================
# Google Gemini (LLM & Document Summarization)
# ==========================================
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# Sarvam AI (High-Quality Text-to-Speech)
# ==========================================
# Get your key at: https://www.sarvam.ai/
SARVAM_API_KEY=your_sarvam_api_key_here

# Select the Sarvam TTS speaker voice
# Options: rahul, priya, simran, shreya, aditya, ritu, ashutosh, neha, pooja, rohan, kavya, etc.
SARVAM_SPEAKER=rahul
